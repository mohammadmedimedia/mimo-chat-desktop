{
  "productName": "MiMo Chat",
  "version": "1.0.0",
  "identifier": "com.mimo.chat",
  "build": {
    "frontendDist": "../index.html"
  },
  "app": {
    "windows": [
      {
        "title": "MiMo Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:* http://localhost:*; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icon.png"
    ],
    "linux": {
      "appimage": {},
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
